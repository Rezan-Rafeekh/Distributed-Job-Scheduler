# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://codity:codity@localhost:5432/codity?schema=public"

# API
API_PORT=4000
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# Optional -- powers the "AI-generated failure summaries" bonus feature only.
# Without it the rest of the platform works normally; the AI summary endpoint
# returns a clean 503 instead of a generated summary.
ANTHROPIC_API_KEY=

# Worker
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL_MS=1500
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_SHUTDOWN_GRACE_MS=30000

# Web
VITE_API_URL="http://localhost:4000"
VITE_WS_URL="ws://localhost:4000"
