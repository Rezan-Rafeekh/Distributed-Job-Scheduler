{
  "name": "codity-job-scheduler",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "npm run migrate --workspace=@codity/db",
    "db:generate": "npm run generate --workspace=@codity/db",
    "db:seed": "npm run seed --workspace=@codity/db",
    "db:studio": "npm run studio --workspace=@codity/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
